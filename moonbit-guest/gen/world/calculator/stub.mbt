///|
pub fn add_points(a : @calculator.Point, b : @calculator.Point) -> @calculator.Point {
	@calculator.Point::{ x: a.x + b.x, y: a.y + b.y }
}

///|
pub fn calculate(
	a : @calculator.Point,
	b : @calculator.Point
) -> @calculator.CalculationResult {
	let sum = add_points(a, b)
	let dx : Double = sum.x.to_double()
	let dy : Double = sum.y.to_double()

	@calculator.CalculationResult::{
		sum,
		distance: (dx * dx + dy * dy).sqrt(),
	}
}

///|
pub fn get_origin() -> @calculator.Point {
	@calculator.Point::{ x: 0, y: 0 }
}
